---
import '../styles/global.css';
import { languages, type Language } from '../i18n/utils';

interface Props {
  title: string;
  lang?: Language;
}

const { title, lang = 'en' } = Astro.props;
---

<!DOCTYPE html class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Elite Paws - Premium Dog Breeders" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@100;300;400;500;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-forest-dark text-white overflow-x-hidden">
    <div class="lang-switcher">
      <a href="/en" class:list={[{ active: lang === 'en' }]} class="text-xs font-bold">EN</a>
      <a href="/es" class:list={[{ active: lang === 'es' }]} class="text-xs font-bold">ES</a>
    </div>
    <slot />
  </body>
</html>

<style>
  .lang-switcher {
    position: fixed;
    top: 1.5rem;
    right: 6rem;
    z-index: 1001;
    display: flex;
    gap: 0.5rem;
    background: rgba(22, 37, 30, 0.9);
    backdrop-filter: blur(8px);
    padding: 0.5rem;
    border-radius: 9999px;
    border: 1px solid rgba(30, 215, 96, 0.2);
  }

  .lang-switcher a {
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 0.75rem;
    color: #94a3b8;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .lang-switcher a:hover {
    color: #1ed760;
  }

  .lang-switcher a.active {
    background: #1ed760;
    color: #0d1b15;
  }
</style>
