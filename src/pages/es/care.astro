const careTopics = [
  { key: 'nutrition', icon: 'restaurant' },
  { key: 'exercise', icon: 'fitness_center' },
  { key: 'grooming', icon: 'content_cut' },
  { key: 'health', icon: 'vaccines' },
];
---

<Layout title="Care Guide - Elite Paws" {lang}>
  <Header t={t} {lang} />
  
  <main class="bg-forest-dark min-h-screen">
    <!-- Hero Section -->
    <div class="relative mb-12 rounded-xl overflow-hidden min-h-[320px] flex flex-col justify-center items-center text-center p-8 bg-forest-card border border-white/5">
      <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, #1ed760 1px, transparent 0); background-size: 40px 40px;"></div>
      <h1 class="text-4xl md:text-6xl font-black text-white mb-4 tracking-tight">{t('care.title')} <span class="text-primary">{t('care.titleHighlight')}</span></h1>
      <p class="text-slate-400 max-w-2xl text-lg mb-8">{t('care.subtitle')}</p>
      <div class="w-full max-w-xl">
        <label class="flex flex-col w-full h-14">
          <div class="flex w-full flex-1 items-stretch rounded-xl h-full shadow-2xl overflow-hidden">
            <div class="text-primary flex border-none bg-forest-dark items-center justify-center pl-5">
              <span class="material-symbols-outlined">search</span>
            </div>
            <input class="form-input flex w-full border-none bg-forest-dark text-white focus:ring-0 px-4 text-base placeholder:text-slate-500" placeholder={t('care.searchPlaceholder')}/>
            <button class="bg-primary text-forest-dark px-6 font-black hover:bg-primary/90 transition-colors">{t('care.searchButton')}</button>
          </div>
        </label>
      </div>
    </div>

    <!-- Core Care Topics Grid -->
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        {careTopics.map(topic => (
          <div class="group bg-forest-card border border-white/5 hover:border-primary/50 p-6 rounded-xl transition-all hover:-translate-y-1">
            <div class="bg-primary/10 w-12 h-12 rounded-lg flex items-center justify-center mb-6 group-hover:bg-primary transition-colors">
              <span class="material-symbols-outlined text-primary group-hover:text-forest-dark text-3xl">{topic.icon}</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">{t(`care.topics.${topic.key}.title`)}</h3>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">{t(`care.topics.${topic.key}.description`)}</p>
            <a class="text-primary text-sm font-semibold flex items-center gap-2 hover:underline" href="#">
              {t('care.breedSection.readGuide')} <span class="material-symbols-outlined text-xs">arrow_forward</span>
            </a>
          </div>
        ))}
      </div>

      <!-- Breed-Specific Tips Section -->
      <section class="mb-20">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-black text-white tracking-tight">{t('care.breedSection.title')} <span class="text-primary">{t('care.breedSection.titleHighlight')}</span></h2>
          <div class="h-px flex-1 bg-white/5 mx-8 hidden md:block"></div>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
          {breeds.map((breed, index) => (
            <button class={`flex flex-col items-center gap-3 p-4 rounded-xl border-2 transition-all ${index === 0 ? 'border-primary bg-forest-card/50' : 'border-white/5 hover:border-primary/50'}`}>
              <div class="size-16 rounded-full bg-cover bg-center border-2" data-alt={breed.name} style={`background-image: url('${breed.image}'); border-color: ${index === 0 ? '#1ed760' : '#333'}`}></div>
              <span class={`text-sm font-bold ${index === 0 ? 'text-white' : 'text-slate-400'}`}>{breed.name}</span>
            </button>
          ))}
        </div>
        
        <div class="bg-forest-card rounded-2xl border border-white/5 p-8 md:p-10 flex flex-col md:flex-row gap-10 items-center">
          <div class="w-full md:w-1/3 aspect-[4/5] rounded-xl bg-cover bg-center overflow-hidden border border-white/5 shadow-xl" data-alt="French Bulldog puppy" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuD46cM6FZUTGtMJ_nkwKk3XgiXmYsriBmgSNcHzWbSuRE9oPM0eF-4bhs-0rN0vRqY7ZM6BEliHSJnkRgZR9c_swOno-ZmlzuzTaUlqhU1tlA7RlciJ9PN9mf2Xmqr2Cd7KmnFY84PARE52SUujlxv9rUFlSjvybtetbFvE9BMdwYYpHn5KCp_ioCBKO-GVIhKTZdUKj03oig-HQNm_sSA9OScOnsox9rFUwvlFKNzI7e3HVNnN-x0on1gV_qPUDfjfOfjZyUT7h1EU')"></div>
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-4">
              <span class="px-3 py-1 bg-primary/20 text-primary text-xs font-bold uppercase rounded-full tracking-wider">{t('care.breedSection.topRecommendation')}</span>
            </div>
            <h3 class="text-3xl font-black text-white mb-4">French Bulldog Care</h3>
            <div class="space-y-4 text-slate-300 leading-relaxed mb-8">
              <div class="flex gap-3">
                <span class="material-symbols-outlined text-primary">check_circle</span>
                <p><strong class="text-white">Temperature Control:</strong> Frenchies are prone to overheating. Avoid long walks in direct sun and keep indoor environments cool.</p>
              </div>
              <div class="flex gap-3">
                <span class="material-symbols-outlined text-primary">check_circle</span>
                <p><strong class="text-white">Facial Hygiene:</strong> Clean facial wrinkles daily with a damp cloth to prevent moisture buildup and irritation.</p>
              </div>
              <div class="flex gap-3">
                <span class="material-symbols-outlined text-primary">check_circle</span>
                <p><strong class="text-white">Weight Management:</strong> Maintain a lean physique to reduce stress on their compact spine and joints.</p>
              </div>
            </div>
            <button class="bg-primary/10 border border-primary text-primary px-8 py-3 rounded-lg font-bold hover:bg-primary hover:text-forest-dark transition-all">{t('care.breedSection.downloadGuide')}</button>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <div class="bg-primary rounded-2xl p-8 md:p-16 text-center relative overflow-hidden group mb-20">
        <div class="relative z-10">
          <h2 class="text-forest-dark text-3xl md:text-5xl font-black mb-6 tracking-tight">{t('care.cta.title')}</h2>
          <p class="text-forest-dark/80 text-lg mb-10 max-w-xl mx-auto font-medium">{t('care.cta.subtitle')}</p>
          <button class="inline-flex items-center gap-3 bg-forest-dark text-primary px-10 py-5 rounded-xl text-xl font-black hover:shadow-[0_0_30px_rgba(30,215,96,0.5)] transition-all transform active:scale-95">
            <span class="material-symbols-outlined text-3xl">chat</span>
            {t('care.cta.button')}
          </button>
        </div>
      </div>
    </div>
  </main>

  <Footer t={t} {lang} />
</Layout>
