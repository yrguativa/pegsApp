---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
const base = '/pegsApp';
---

<Layout title="About Us - Royal Puppy House" {lang}>
  <Header t={t} {lang} />
  
  <main class="bg-forest-dark min-h-screen">
    <!-- Hero Section -->
    <section class="relative py-32 px-6 overflow-hidden">
      <div class="max-w-7xl mx-auto relative z-10 text-center">
        <h2 class="text-primary font-bold tracking-widest text-sm mb-4 uppercase">{t('about.badge')}</h2>
        <h1 class="text-5xl md:text-7xl font-black text-white mb-6">{t('about.title')} <span class="text-primary">{t('about.titleHighlight')}</span></h1>
        <p class="max-w-2xl mx-auto text-lg text-slate-300">{t('about.subtitle')}</p>
      </div>
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_50%_50%,#1ed760_0%,transparent_70%)]"></div>
      </div>
    </section>

    <!-- Timeline Section -->
    <section class="max-w-6xl mx-auto px-6 pb-32">
      <div class="relative">
        <!-- Central Line -->
        <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-1 bg-gradient-to-b from-primary to-primary/20 rounded-full opacity-50 md:block hidden"></div>
        
        <!-- Milestone 2010 -->
        <div class="relative flex flex-col md:flex-row items-center justify-between mb-32 group">
          <div class="w-full md:w-[45%] mb-8 md:mb-0">
            <div class="bg-forest-card p-1 rounded-xl overflow-hidden border border-white/5 transition-all hover:border-primary/30">
              <div class="w-full h-[300px] bg-cover bg-center rounded-lg" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAqGILObouqpeZcG2n9rMBGpuNtOXehC6Bq8ellVCnRI7dai_nF6k7qV5_2rPv6kWj0wAeFBge3ZqhZEYbrW1nKeduN06cxM0bk3OUbwdCRjvgP9qE6ZC-P46ym5hoNhY4MauY5wpbXRIrilwrjmTKKShg0rMkiClsA9GCVUNqwcuYkDYBF08LZkfIsgxYGggSOvjW4NhAUSlap8h9X4RUzZkCCDDaiwaGzn_Ww2ivOaB8ivB63ZpOtB5whub98HnNb4_V2h-wmXpRl')"></div>
            </div>
          </div>
          <div class="absolute left-1/2 transform -translate-x-1/2 size-12 bg-forest-dark border-4 border-primary rounded-full z-10 hidden md:flex items-center justify-center shadow-[0_0_15px_#1ed760]">
            <span class="material-symbols-outlined text-primary text-xl">star</span>
          </div>
          <div class="w-full md:w-[45%] text-left md:pl-12">
            <span class="text-5xl font-bold text-primary block mb-2">2010</span>
            <h3 class="text-2xl font-bold text-white mb-4">{t('about.timeline.2010.title')}</h3>
            <p class="text-slate-400 leading-relaxed">{t('about.timeline.2010.description')}</p>
          </div>
        </div>

        <!-- Milestone 2015 -->
        <div class="relative flex flex-col md:flex-row-reverse items-center justify-between mb-32 group">
          <div class="w-full md:w-[45%] mb-8 md:mb-0">
            <div class="bg-forest-card p-1 rounded-xl overflow-hidden border border-white/5 transition-all hover:border-primary/30">
              <div class="w-full h-[300px] bg-cover bg-center rounded-lg" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCPIk_sqods9aNQkv-F1DLZHG4k20q77jFShaincObAQa0z7ZwfBmiOAyb4Aeu0XzDJF9tpQoRV2lMW_GVwmrq9tRCd2_T6nCVs1pqx39exdFcmxEyNOoNVvWg-D0bH0RMJqrI5LJtesaDFF5AyJabAURlS-4Vnrf8j4lYbAbcbfrcIszoyJJws4ZIHErT5TISr8IwrSjaA2YVMz3fM0XpNpPBc5QmR_rS97ut_RevKMUxdTbPKDVZwLXYeiQF8xgWOrr43zQkOvXzE')"></div>
            </div>
          </div>
          <div class="absolute left-1/2 transform -translate-x-1/2 size-12 bg-forest-dark border-4 border-primary rounded-full z-10 hidden md:flex items-center justify-center shadow-[0_0_15px_#1ed760]">
            <span class="material-symbols-outlined text-primary text-xl">verified</span>
          </div>
          <div class="w-full md:w-[45%] text-left md:pr-12 md:text-right">
            <span class="text-5xl font-bold text-primary block mb-2">2015</span>
            <h3 class="text-2xl font-bold text-white mb-4">{t('about.timeline.2015.title')}</h3>
            <p class="text-slate-400 leading-relaxed">{t('about.timeline.2015.description')}</p>
          </div>
        </div>

        <!-- Milestone 2020 -->
        <div class="relative flex flex-col md:flex-row items-center justify-between mb-32 group">
          <div class="w-full md:w-[45%] mb-8 md:mb-0">
            <div class="bg-forest-card p-1 rounded-xl overflow-hidden border border-white/5 transition-all hover:border-primary/30">
              <div class="w-full h-[300px] bg-cover bg-center rounded-lg" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAvx0DIEQq2lBtQNhU493HP-kNntYEQxzXfP_HIDguBVpwj7l20eWCJM5Tvem19UjKAYn9B1WN4QYI1W0zHEPI_KHXZY8F92LKO2tfiY-wScH1n6pJafMaGlOqjJJpD1RrXxW39rA-qcE7hW8atCZWZ5sV9TJWaayzwiaEW7GaEjJkIAgqMDwidlJ5V9UrpGsahTfkOmBkgkmLlr9FWlc59kLbGKYkz_yJvqUsIqIe6hbwRsOrLZKaS-s0H1iysx6CCe_-4C6HkLdb0')"></div>
            </div>
          </div>
          <div class="absolute left-1/2 transform -translate-x-1/2 size-12 bg-forest-dark border-4 border-primary rounded-full z-10 hidden md:flex items-center justify-center shadow-[0_0_15px_#1ed760]">
            <span class="material-symbols-outlined text-primary text-xl">home_health</span>
          </div>
          <div class="w-full md:w-[45%] text-left md:pl-12">
            <span class="text-5xl font-bold text-primary block mb-2">2020</span>
            <h3 class="text-2xl font-bold text-white mb-4">{t('about.timeline.2020.title')}</h3>
            <p class="text-slate-400 leading-relaxed">{t('about.timeline.2020.description')}</p>
          </div>
        </div>

        <!-- Milestone 2024 -->
        <div class="relative flex flex-col md:flex-row-reverse items-center justify-between group">
          <div class="w-full md:w-[45%] mb-8 md:mb-0">
            <div class="bg-forest-card p-1 rounded-xl overflow-hidden border border-white/5 transition-all hover:border-primary/30">
              <div class="w-full h-[300px] bg-cover bg-center rounded-lg" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAPJo4TKxetZcAd-i-wtozcVymRmd58prZ8cFylADrkFRMHPa5HdHOhrpXjjTgkfPB9t05J-ZiJm5O7fEXPqA8K93bHqE7rSnxUdbyQmitUL0ELYj-Z_GQJazFKvArqOJeLpFUp51jmKka3bLaok-azmifv3i60sBrDHFpimBZjL8CjmJUudvAa5Ld9SXIl1UfkL6PGG4SqObF1VFOxXd5X4doD6PGEt8JFaA-WGaHSf5Nyb3esukjbIgnB-mWDvXnc6ZFfNwARxiSj')"></div>
            </div>
          </div>
          <div class="absolute left-1/2 transform -translate-x-1/2 size-12 bg-forest-dark border-4 border-primary rounded-full z-10 hidden md:flex items-center justify-center shadow-[0_0_15px_#1ed760]">
            <span class="material-symbols-outlined text-primary text-xl">language</span>
          </div>
          <div class="w-full md:w-[45%] text-left md:pr-12 md:text-right">
            <span class="text-5xl font-bold text-primary block mb-2">2024</span>
            <h3 class="text-2xl font-bold text-white mb-4">{t('about.timeline.2024.title')}</h3>
            <p class="text-slate-400 leading-relaxed">{t('about.timeline.2024.description')}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="bg-forest-card border-y border-white/5 py-20 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          <div class="flex flex-col gap-2">
            <p class="text-primary text-5xl font-black">14+</p>
            <p class="text-sm font-medium uppercase tracking-widest text-slate-500">{t('about.statsYears')}</p>
          </div>
          <div class="flex flex-col gap-2">
            <p class="text-primary text-5xl font-black">500+</p>
            <p class="text-sm font-medium uppercase tracking-widest text-slate-500">{t('about.statsFamilies')}</p>
          </div>
          <div class="flex flex-col gap-2">
            <p class="text-primary text-5xl font-black">12</p>
            <p class="text-sm font-medium uppercase tracking-widest text-slate-500">{t('about.statsChampions')}</p>
          </div>
          <div class="flex flex-col gap-2">
            <p class="text-primary text-5xl font-black">100%</p>
            <p class="text-sm font-medium uppercase tracking-widest text-slate-500">{t('about.statsGuarantee')}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-32 px-6">
      <div class="max-w-4xl mx-auto text-center bg-gradient-to-br from-primary/10 to-transparent p-12 rounded-[2rem] border border-primary/20 relative overflow-hidden">
        <div class="relative z-10">
          <h2 class="text-4xl font-black text-white mb-6">{t('about.ctaTitle')}</h2>
          <p class="text-lg mb-10 text-slate-400">{t('about.ctaSubtitle')}</p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href={`${base}/${lang}#puppies`} class="bg-primary text-forest-dark px-10 py-4 rounded-xl font-black text-lg hover:scale-105 transition-transform">{t('about.ctaButton')}</a>
            <button class="bg-white/5 text-white px-10 py-4 rounded-xl font-black text-lg border border-white/10 hover:bg-white/10 transition-all">{t('about.ctaSecondary')}</button>
          </div>
        </div>
        <div class="absolute -top-24 -right-24 size-64 bg-primary/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 size-64 bg-primary/10 rounded-full blur-3xl"></div>
      </div>
    </section>
  </main>

  <Footer t={t} {lang} />
</Layout>
