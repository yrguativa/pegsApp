<section class="cta" id="book">
  <div class="container cta-container">
    <h2 class="cta-title">Ready to Give Your Pet the Best Care?</h2>
    <p class="cta-subtitle">Book an appointment today and let us pamper your furry friend</p>
    <a href="#contact" class="btn btn-primary">Book Now</a>
  </div>
</section>

<style>
  .cta {
    padding: var(--spacing-xl) 0;
    background-color: var(--color-secondary);
  }

  .cta-container {
    text-align: center;
  }

  .cta-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 1rem;
  }

  .cta-subtitle {
    font-size: 1.125rem;
    color: var(--color-accent);
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta .btn-primary {
    background-color: var(--color-primary);
  }

  .cta .btn-primary:hover {
    background-color: #d14f00;
  }

  @media (max-width: 768px) {
    .cta-title {
      font-size: 2rem;
    }
  }
</style>
