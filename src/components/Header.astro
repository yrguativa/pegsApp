---
interface Props {
  t: {
    (key: string): string;
  };
  lang: "en" | "es";
}

const { t, lang } = Astro.props;
const base = "/pegsApp";
---

<header
  class="fixed top-0 z-50 w-full glass-effect border-b border-white/5 px-6 lg:px-20 py-4"
>
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <div class="flex items-center gap-3">
      <a href={`${base}/${lang}`} class="flex items-center gap-3">
        <img
          src="/pegsApp/logo.svg"
          alt="Royal Puppy House"
          class="w-10 h-10"
        />
        <div class="flex flex-col">
          <h1
            class="text-xl font-black tracking-tight text-white italic uppercase leading-none"
          >
            Royal Puppy
          </h1>
          <span class="text-[10px] text-primary font-bold tracking-[0.3em]"
            >House</span
          >
        </div>
      </a>
    </div>
    <nav class="hidden md:flex items-center gap-10">
      <a
        class="text-sm font-medium text-slate-300 hover:text-primary transition-colors"
        href={`${base}/${lang}#puppies`}>{t("nav.available")}</a
      >
      <a
        class="text-sm font-medium text-slate-300 hover:text-primary transition-colors"
        href={`${base}/${lang}/care`}>{t("nav.care")}</a
      >
      <a
        class="text-sm font-medium text-slate-300 hover:text-primary transition-colors"
        href={`${base}/${lang}/about`}>{t("nav.story")}</a
      >
      <a
        class="text-sm font-medium text-slate-300 hover:text-primary transition-colors"
        href="#process">{t("nav.process")}</a
      >
      <a
        class="text-sm font-medium text-slate-300 hover:text-primary transition-colors"
        href={`${base}/${lang}#testimonials`}>{t("nav.testimonials")}</a
      >
    </nav>
    <div class="flex items-center gap-3">
      <div class="lang-switcher hidden md:flex">
        <a
          href={`${base}/en`}
          class:list={[{ active: lang === "en" }]}
          class="text-xs font-bold">EN</a
        >
        <a
          href={`${base}/es`}
          class:list={[{ active: lang === "es" }]}
          class="text-xs font-bold">ES</a
        >
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-white p-2">
        <span class="material-symbols-outlined text-2xl">menu</span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] bg-forest-dark/95 backdrop-blur-xl translate-x-full transition-transform duration-300 md:hidden"
>
  <div class="flex flex-col h-full p-6 pt-24">
    <button id="close-menu-btn" class="absolute top-6 right-6 text-white p-2">
      <span class="material-symbols-outlined text-3xl">close</span>
    </button>
    <nav class="flex flex-col gap-6">
      <a
        class="text-xl font-bold text-white hover:text-primary transition-colors"
        href={`${base}/${lang}#puppies`}>{t("nav.available")}</a
      >
      <a
        class="text-xl font-bold text-white hover:text-primary transition-colors"
        href={`${base}/${lang}/care`}>{t("nav.care")}</a
      >
      <a
        class="text-xl font-bold text-white hover:text-primary transition-colors"
        href={`${base}/${lang}/about`}>{t("nav.story")}</a
      >
      <a
        class="text-xl font-bold text-white hover:text-primary transition-colors"
        href="#process">{t("nav.process")}</a
      >
      <a
        class="text-xl font-bold text-white hover:text-primary transition-colors"
        href={`${base}/${lang}#testimonials`}>{t("nav.testimonials")}</a
      >
    </nav>
    <div class="mt-auto flex flex-col items-center gap-4">
      <div class="lang-switcher w-30">
        <a
          href={`${base}/en`}
          class:list={[{ active: lang === "en" }]}
          class="text-xs font-bold">EN</a
        >
        <a
          href={`${base}/es`}
          class:list={[{ active: lang === "es" }]}
          class="text-xs font-bold">ES</a
        >
      </div>
    </div>
  </div>
</div>

<script>
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const closeMenuBtn = document.getElementById("close-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  mobileMenuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.remove("translate-x-full");
  });

  closeMenuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.add("translate-x-full");
  });
</script>


<style>
  .lang-switcher {
    gap: 0.5rem;
    background: rgba(22, 37, 30, 0.9);
    backdrop-filter: blur(8px);
    padding: 0.5rem;
    border-radius: 9999px;
    border: 1px solid rgba(30, 215, 96, 0.2);
  }

  .lang-switcher a {
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 0.75rem;
    color: #94a3b8;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .lang-switcher a:hover {
    color: #1ed760;
  }

  .lang-switcher a.active {
    background: #1ed760;
    color: #0d1b15;
  }
</style>