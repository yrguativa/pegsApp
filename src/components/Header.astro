---
interface Props {
  t: {
    (key: string): string;
  };
  lang: 'en' | 'es';
}

const { t, lang } = Astro.props;
const base = '/pegsApp';
---

<header class="fixed top-0 z-50 w-full glass-effect border-b border-white/5 px-6 lg:px-20 py-4">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <div class="flex items-center gap-3">
      <a href={`${base}/${lang === 'en' ? 'en' : 'es'}`} class="flex items-center gap-3">
        <img src="/pegsApp/logo.svg" alt="Royal Puppy House" class="w-10 h-10" />
        <div class="flex flex-col">
          <h1 class="text-xl font-black tracking-tight text-white italic uppercase leading-none">Royal Puppy House</h1>
          <span class="text-[10px] text-primary font-bold tracking-[0.3em]">EST. 2024</span>
        </div>
      </a>
    </div>
    <nav class="hidden md:flex items-center gap-10">
      <a class="text-sm font-medium text-slate-300 hover:text-primary transition-colors" href="#puppies">{t('nav.available')}</a>
      <a class="text-sm font-medium text-slate-300 hover:text-primary transition-colors" href="#story">{t('nav.story')}</a>
      <a class="text-sm font-medium text-slate-300 hover:text-primary transition-colors" href="#process">{t('nav.process')}</a>
      <a class="text-sm font-medium text-slate-300 hover:text-primary transition-colors" href="#testimonials">{t('nav.testimonials')}</a>
    </nav>
    <div class="flex items-center gap-4">
      <button class="hidden lg:flex items-center justify-center rounded-full h-11 px-8 bg-primary text-forest-dark text-sm font-black tracking-wide hover:bg-primary-dark transition-all shadow-[0_0_20px_rgba(30,215,96,0.3)]">
        {t('header.inquire')}
      </button>
      <button class="md:hidden text-white">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>
</header>
