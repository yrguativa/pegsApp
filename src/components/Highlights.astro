---

<section class="py-24 bg-forest-dark overflow-hidden">
  <div class="px-6 lg:px-20 mb-12 flex flex-col md:flex-row md:items-center justify-between gap-6">
    <div data-aos="fade-right" class="flex items-center gap-4">
      <span class="material-symbols-outlined text-primary text-4xl">photo_camera</span>
      <h2 class="text-3xl md:text-4xl font-black text-white uppercase tracking-tight">{t('highlights.title')}</h2>
    </div>
    <a data-aos="fade-left" data-aos-delay="100" class="text-primary font-bold flex items-center gap-2 hover:translate-x-1 transition-transform group" href="#">
      {t('highlights.viewAll')} <span class="material-symbols-outlined text-xl group-hover:ml-1 transition-all">arrow_forward</span>
    </a>
  </div>
  <div class="flex gap-6 overflow-x-auto pb-10 px-6 lg:px-20 no-scrollbar">
    {highlights.map((item, index) => (
      <div data-aos="fade-up" data-aos-delay={index * 100} class="flex-none w-44 md:w-56 group cursor-pointer">
        <div class="relative aspect-[9/16] rounded-3xl overflow-hidden border-2 border-primary/20 hover:border-primary p-1.5 transition-all duration-500">
          <div class="w-full h-full rounded-2xl overflow-hidden relative">
            <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" src={item.image} alt={t(`highlights.${item.label}`)} />
            <div class="absolute inset-0 bg-gradient-to-t from-forest-dark/80 via-transparent to-transparent"></div>
            <span class="absolute bottom-4 left-4 text-white text-xs font-black tracking-widest uppercase">{t(`highlights.${item.label}`)}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
  <div data-aos="fade-up" data-aos-delay="600" class="text-center mt-8">
    <p class="text-slate-400 text-sm italic">{t('highlights.followers')}</p>
    <button class="mt-6 inline-flex items-center gap-3 px-10 py-4 rounded-full border border-primary/30 text-white font-black text-sm tracking-widest hover:bg-primary/10 transition-all uppercase">
      {t('highlights.follow')}
    </button>
  </div>
</section>
