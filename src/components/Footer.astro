---
interface Props {
  t: {
    (key: string): string;
  };
  lang: 'en' | 'es';
}

const { t, lang } = Astro.props;
const base = '/pegsApp';
---

<footer class="bg-forest-dark border-t border-white/5 py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-16 mb-20">
      <div class="col-span-1">
        <div class="flex items-center gap-3 mb-8">
          <a href={`${base}/${lang}`} class="flex items-center gap-3">
            <img src="/pegsApp/logo.svg" alt="Elite Paws" class="w-12 h-12" />
            <div class="flex flex-col">
              <h2 class="text-2xl font-black tracking-tight text-white italic uppercase leading-none">Elite Paws</h2>
              <span class="text-[10px] text-primary font-bold tracking-[0.3em]">EST. 2024</span>
            </div>
          </a>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed mb-8">
          {t('footer.description')}
        </p>
        <div class="flex gap-5">
          <a class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-slate-400 hover:text-primary hover:border-primary transition-all" href="#"><span class="material-symbols-outlined text-xl">camera</span></a>
          <a class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-slate-400 hover:text-primary hover:border-primary transition-all" href="#"><span class="material-symbols-outlined text-xl">play_circle</span></a>
          <a class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-slate-400 hover:text-primary hover:border-primary transition-all" href="#"><span class="material-symbols-outlined text-xl">mail</span></a>
        </div>
      </div>
      <div>
        <h4 class="text-white font-black mb-8 text-xs uppercase tracking-[0.2em]">{t('footer.quickLinks')}</h4>
        <ul class="space-y-4 text-sm text-slate-400">
          <li><a class="hover:text-primary transition-colors" href="#">{t('footer.links.puppies')}</a></li>
          <li><a class="hover:text-primary transition-colors" href="#">{t('footer.links.gallery')}</a></li>
          <li><a class="hover:text-primary transition-colors" href="#">{t('footer.links.process')}</a></li>
          <li><a class="hover:text-primary transition-colors" href="#">{t('footer.links.policy')}</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-black mb-8 text-xs uppercase tracking-[0.2em]">{t('footer.resources')}</h4>
        <ul class="space-y-4 text-sm text-slate-400">
          <li><a class="hover:text-primary transition-colors" href="#">{t('footer.resourcesList.health')}</a></li>
          <li><a class="hover:text-primary transition-colors" href="#">{t('footer.resourcesList.guide')}</a></li>
          <li><a class="hover:text-primary transition-colors" href="#">{t('footer.resourcesList.nutrition')}</a></li>
          <li><a class="hover:text-primary transition-colors" href="#">{t('footer.resourcesList.vet')}</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-black mb-8 text-xs uppercase tracking-[0.2em]">{t('footer.newsletter')}</h4>
        <p class="text-sm text-slate-400 mb-6 font-light">{t('footer.newsletterText')}</p>
        <div class="flex flex-col gap-3">
          <input class="bg-forest-card border border-white/10 rounded-xl px-5 py-3 text-sm text-white focus:outline-none focus:border-primary" placeholder={t('footer.emailPlaceholder')} type="email"/>
          <button class="bg-primary text-forest-dark text-xs font-black py-3 rounded-xl hover:bg-primary-dark transition-all uppercase tracking-widest">{t('footer.subscribe')}</button>
        </div>
      </div>
    </div>
    <div class="pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] text-slate-500 font-bold uppercase tracking-widest">
      <p>© 2024 Elite Paws Luxury Breeders. {t('footer.copyright')}</p>
      <div class="flex gap-8">
        <a class="hover:text-white transition-colors" href="#">{t('footer.privacy')}</a>
        <a class="hover:text-white transition-colors" href="#">{t('footer.terms')}</a>
        <a class="hover:text-white transition-colors" href="#">{t('footer.cookies')}</a>
      </div>
    </div>
  </div>
</footer>
