---
interface Props {
  t: {
    (key: string): string;
  };
  lang: 'en' | 'es';
}

const { t, lang } = Astro.props;
---

<section class="py-32 bg-forest-dark" id="puppies">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-20">
      <h2 class="text-5xl font-black text-white mb-6 uppercase tracking-tight">{t('pups.title')}</h2>
      <div class="w-24 h-1.5 bg-primary mx-auto rounded-full mb-8"></div>
      <p class="text-slate-300 max-w-2xl mx-auto text-lg">{t('pups.subtitle')}</p>
    </div>
    <div id="puppies-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      <div class="col-span-full text-center text-slate-400">
        <span class="inline-block animate-pulse">Loading puppies...</span>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ t, lang }}>
const CACHE_KEY = 'elite_paws_data';
const CACHE_DURATION = 4 * 60 * 60 * 1000;

const translations = {
  pups: {
    badges: {
      new: lang === 'es' ? 'Nuevo' : 'New',
      reserved: lang === 'es' ? 'Reservado' : 'Reserved',
      popular: lang === 'es' ? 'Popular' : 'Popular'
    },
    viewDetails: lang === 'es' ? 'Ver Detalles' : 'View Details',
    notAvailable: lang === 'es' ? 'No Disponible' : 'Not Available'
  }
};

async function getCachedData() {
  const cached = localStorage.getItem(CACHE_KEY);
  
  if (cached) {
    try {
      const { data, timestamp } = JSON.parse(cached);
      const now = Date.now();
      
      if (now - timestamp < CACHE_DURATION) {
        return data;
      }
    } catch (e) {}
  }
  
  const response = await fetch('/data.json');
  const data = await response.json();
  
  localStorage.setItem(CACHE_KEY, JSON.stringify({
    data,
    timestamp: Date.now()
  }));
  
  return data;
}

async function renderPuppies() {
  const data = await getCachedData();
  const puppies = data.puppies;
  const grid = document.getElementById('puppies-grid');
  
  if (!grid) return;
  
  grid.innerHTML = puppies.map(pup => {
    const breed = lang === 'es' ? pup.breed_es : pup.breed;
    const age = lang === 'es' ? pup.age_es : pup.age;
    const gender = lang === 'es' ? pup.gender_es : pup.gender;
    const isAvailable = pup.available !== false;
    const badgeLabel = translations.pups.badges[pup.badge];
    
    return `
      <div class="bg-forest-card rounded-[2.5rem] overflow-hidden border border-white/5 group hover:border-primary/30 transition-all duration-500 shadow-xl">
        <div class="relative aspect-square overflow-hidden m-4 rounded-[2rem]">
          <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" src="${pup.image}" alt="${pup.name}" />
          <div class="absolute top-4 left-4 text-[10px] font-black px-4 py-1.5 rounded-full uppercase tracking-widest ${pup.badge === 'reserved' ? 'bg-white/20 backdrop-blur-md text-white' : 'bg-primary text-forest-dark'}">
            ${badgeLabel}
          </div>
        </div>
        <div class="p-8 pt-2">
          <div class="flex justify-between items-start mb-6">
            <div>
              <h3 class="text-2xl font-black text-white tracking-tight">${pup.name}</h3>
              <p class="text-slate-400 text-sm">${breed}</p>
            </div>
            <span class="text-primary font-black text-2xl">${pup.price}</span>
          </div>
          <div class="flex items-center justify-between mb-8 pb-6 border-b border-white/5">
            <div class="flex gap-2">
              <span class="material-symbols-outlined text-primary text-sm">cake</span>
              <span class="text-sm text-slate-300">${age}</span>
            </div>
            <div class="flex gap-2">
              <span class="material-symbols-outlined text-primary text-sm">pets</span>
              <span class="text-sm text-slate-300">${gender}</span>
            </div>
          </div>
          ${isAvailable ? `
            <button class="w-full py-4 rounded-2xl bg-primary text-forest-dark font-black tracking-widest uppercase hover:bg-primary-dark transition-all flex items-center justify-center gap-2">
              ${translations.pups.viewDetails} <span class="material-symbols-outlined text-sm">favorite</span>
            </button>
          ` : `
            <button class="w-full py-4 rounded-2xl border border-white/10 text-slate-500 font-black tracking-widest uppercase cursor-not-allowed">
              ${translations.pups.notAvailable}
            </button>
          `}
        </div>
      </div>
    `;
  }).join('');
}

document.addEventListener('DOMContentLoaded', renderPuppies);
</script>
